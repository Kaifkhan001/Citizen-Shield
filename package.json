{
  "name": "citizen-shield",
  "version": "0.1.0",
  "private": true,
  "description": "Citizen Shield monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @citizen-shield/database prisma:generate",
    "db:migrate": "pnpm --filter @citizen-shield/database prisma:migrate",
    "db:seed": "pnpm --filter @citizen-shield/database prisma:seed",
    "db:studio": "pnpm --filter @citizen-shield/database prisma:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
