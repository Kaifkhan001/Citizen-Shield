DATABASE_URL=postgresql://postgres:postgres@localhost:5432/citizen_shield
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me-with-a-long-random-string
NEXT_PUBLIC_API_URL=http://localhost:3001/api
BACKEND_PORT=3001
WEB_PORT=3000
LOG_LEVEL=info
WEB_ORIGINS=http://localhost:3000

# Rate limiting. Defaults: 100 req / 60s globally, 5 req / 60s on /auth/*.
# In production, leave defaults; in tests, override the AUTH_* values so a
# single suite can issue many requests without tripping the limiter.
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100
AUTH_RATE_LIMIT_TTL=60000
AUTH_RATE_LIMIT_LIMIT=5

# M4 — AI intake. `mock` is the default and has no external dependency;
# switch to `openai` and provide OPENAI_API_KEY for live behavior.
AI_PROVIDER=mock
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2
# OPENAI_API_KEY=sk-...
AI_RATE_LIMIT_TTL=60000
AI_RATE_LIMIT_LIMIT=20
INTAKE_MAX_MESSAGES=20
